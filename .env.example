NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-optional
NEXT_PUBLIC_SUPABASE_DB_SCHEMA=app_prod
SUPABASE_PLAYER_PHOTOS_BUCKET=player-photos

# Ambiente local (desarrollo) separado:
# Si corres `npm run dev`, estas variables se priorizan automaticamente.
NEXT_PUBLIC_SUPABASE_URL_DEV=https://your-dev-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY_DEV=sb_publishable_dev_xxx
SUPABASE_SERVICE_ROLE_KEY_DEV=your-dev-service-role-key
NEXT_PUBLIC_SUPABASE_DB_SCHEMA_DEV=app_dev
SUPABASE_PLAYER_PHOTOS_BUCKET_DEV=player-photos-dev

# Opcional: forzar ambiente objetivo de Supabase (dev|prod)
# SUPABASE_TARGET_ENV=development

# Alternativas compatibles:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# NEXT_PUBLIC_SUPABASE_ANON_KEY=legacy-anon-or-publishable-key

# Variables para script de copia de bucket entre ambientes:
# SUPABASE_COPY_SOURCE_URL=https://source-project.supabase.co
# SUPABASE_COPY_SOURCE_SERVICE_ROLE_KEY=source-service-role-key
# SUPABASE_COPY_TARGET_URL=https://target-project.supabase.co
# SUPABASE_COPY_TARGET_SERVICE_ROLE_KEY=target-service-role-key
# SUPABASE_COPY_BUCKET=player-photos
# SUPABASE_COPY_SOURCE_BUCKET=player-photos
# SUPABASE_COPY_TARGET_BUCKET=player-photos-dev
