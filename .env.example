# Recomendado:
# - copiar a `.env.development.local` para desarrollo
# - copiar a `.env.production.local` para pruebas de produccion local
# En hosting, configura variables en el panel del proveedor.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-optional
NEXT_PUBLIC_SUPABASE_DB_SCHEMA=app_prod
SUPABASE_PLAYER_PHOTOS_BUCKET=player-photos

# URLs canonicas de la app:
# APP_URL se usa en server (retornos, redirects, webhook helpers)
# NEXT_PUBLIC_APP_URL solo si necesitas exponerla en cliente.
# APP_URL=https://tu-dominio.com
# NEXT_PUBLIC_APP_URL=https://tu-dominio.com
# Ads / placeholders:
# NEXT_PUBLIC_ENABLE_ADS=false

# Ambiente local (desarrollo) separado:
# Si corres `npm run dev`, estas variables se priorizan automaticamente.
NEXT_PUBLIC_SUPABASE_URL_DEV=https://your-dev-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY_DEV=sb_publishable_dev_xxx
SUPABASE_SERVICE_ROLE_KEY_DEV=your-dev-service-role-key
NEXT_PUBLIC_SUPABASE_DB_SCHEMA_DEV=app_dev
SUPABASE_PLAYER_PHOTOS_BUCKET_DEV=player-photos-dev

# Opcional: forzar ambiente objetivo de Supabase (dev|prod)
# SUPABASE_TARGET_ENV=development

# Mercado Pago (Checkout Pro)
# Usa token TEST en desarrollo y APP_USR en produccion.
# MERCADOPAGO_ACCESS_TOKEN_DEV=TEST-xxxxxxxx
# MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxx
# Se usa para validar firma de webhooks (recomendado).
# MERCADOPAGO_WEBHOOK_SECRET_DEV=xxxxxxxx
# MERCADOPAGO_WEBHOOK_SECRET=xxxxxxxx
# URL publica base para que Mercado Pago llegue al webhook.
# En DEV puedes usar ngrok/cloudflared:
# MERCADOPAGO_WEBHOOK_BASE_URL_DEV=https://tu-url-publica.ngrok-free.app
# MERCADOPAGO_WEBHOOK_BASE_URL=https://tu-dominio-real.com
# Sandbox por ambiente:
# MERCADOPAGO_USE_SANDBOX_DEV=true
# MERCADOPAGO_USE_SANDBOX=false

# Feedback por email (formulario de Contacto):
# Usa Resend para enviar sugerencias/quejas por correo.
# RESEND_API_KEY_DEV=re_xxx
# RESEND_API_KEY=re_xxx
# Si no defines FEEDBACK_FROM_EMAIL, se usa Fabrica de Futbol <no-reply@fabricadefutbol.com.ar>.
# FEEDBACK_FROM_EMAIL_DEV=Fabrica de Futbol <no-reply@fabricadefutbol.com.ar>
# FEEDBACK_FROM_EMAIL=Fabrica de Futbol <no-reply@fabricadefutbol.com.ar>
# FEEDBACK_TO_EMAIL_DEV=info@fabricadefutbol.com.ar
# FEEDBACK_TO_EMAIL=info@fabricadefutbol.com.ar

# Alternativas compatibles:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# NEXT_PUBLIC_SUPABASE_ANON_KEY=legacy-anon-or-publishable-key

# Variables para script de copia de bucket entre ambientes:
# SUPABASE_COPY_SOURCE_URL=https://source-project.supabase.co
# SUPABASE_COPY_SOURCE_SERVICE_ROLE_KEY=source-service-role-key
# SUPABASE_COPY_TARGET_URL=https://target-project.supabase.co
# SUPABASE_COPY_TARGET_SERVICE_ROLE_KEY=target-service-role-key
# SUPABASE_COPY_BUCKET=player-photos
# SUPABASE_COPY_SOURCE_BUCKET=player-photos
# SUPABASE_COPY_TARGET_BUCKET=player-photos-dev
