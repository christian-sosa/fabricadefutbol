# Copia este archivo a `.env.test` para habilitar Playwright smoke contra un
# entorno aislado de pruebas. Nunca uses credenciales productivas.

SUPABASE_TARGET_ENV=development

# Proyecto / schema de prueba
NEXT_PUBLIC_SUPABASE_URL_DEV=https://your-test-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY_DEV=sb_publishable_test_xxx
SUPABASE_SERVICE_ROLE_KEY_DEV=your-test-service-role-key
NEXT_PUBLIC_SUPABASE_DB_SCHEMA_DEV=app_dev
SUPABASE_PLAYER_PHOTOS_BUCKET_DEV=player-photos-dev

# App local para Playwright
E2E_BASE_URL=http://127.0.0.1:3001
APP_URL_DEV=http://127.0.0.1:3001
NEXT_PUBLIC_APP_URL_DEV=http://127.0.0.1:3001

# Credenciales del admin de prueba que global-setup crea o actualiza.
E2E_ADMIN_EMAIL=e2e-admin@example.com
E2E_ADMIN_PASSWORD=ChangeMe123!
E2E_ORG_SLUG=e2e-fabrica
E2E_ORG_NAME=Organizacion E2E

# Opcional: super admin para evitar warnings y cubrir ramas de admin elevadas.
SUPER_ADMIN_EMAIL=e2e-admin@example.com
